  <!-- BEGIN app block: shopify://apps/wsh-wholesale-pricing/blocks/app-embed/94cbfa01-7191-4bb2-bcd8-b519b9b3bd06 --><script>

  window.wpdExtensionIsProductPage = {"id":8403375161509,"title":"Mercedes Sprinter OEM Style Half-Slider Window","handle":"mercedes-sprinter-oem-style-half-slider-window","description":"\u003cdiv style=\"border: 1px solid rgba(0,0,0,.10); border-radius: 16px; padding: 18px 20px; background: #fff; box-shadow: 0 14px 28px rgba(0,0,0,.06); margin: 22px 0;\" class=\"tv-specCard\"\u003e\n\u003cdiv style=\"display: flex; align-items: flex-start; justify-content: space-between; gap: 18px; padding: 12px 0;\"\u003e\n\u003cdiv style=\"font-size: 11px; letter-spacing: .20em; text-transform: uppercase; color: rgba(0,0,0,.55); min-width: 120px; flex-shrink: 0;\"\u003eShipping\u003c\/div\u003e\n\u003cdiv style=\"font-size: 14.5px; font-weight: 600; color: #111; text-align: right; line-height: 1.4;\"\u003eFlat-Rate $300 Shipping Across the Lower 48 · Flat-Rate $200 Shipping Throughout Canada\u003c\/div\u003e\n\u003c\/div\u003e\n\u003cdiv style=\"display: flex; align-items: flex-start; justify-content: space-between; gap: 18px; padding: 12px 0; border-top: 1px solid rgba(0,0,0,.08);\"\u003e\n\u003cdiv style=\"font-size: 11px; letter-spacing: .20em; text-transform: uppercase; color: rgba(0,0,0,.55); min-width: 120px; flex-shrink: 0;\"\u003ePickup\u003c\/div\u003e\n\u003cdiv style=\"font-size: 14.5px; font-weight: 600; color: #111; text-align: right; line-height: 1.4;\"\u003eFree Warehouse Pickup\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003cp\u003eOEM-style half-slider window engineered exclusively for Mercedes Sprinter vans. Features single-pane tempered glass with flush-closing slider design and integrated bug screen. Professional-grade quality with unique flush fitment that eliminates the traditional indent.\u003c\/p\u003e\n\u003ch3\u003eKey Features\u003c\/h3\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eUnique Flush-Close Design\u003c\/strong\u003e – Slider closes completely flush with window frame, no indent or gap\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSingle-Pane Tempered Glass\u003c\/strong\u003e – DOT-approved safety glass for durability and clarity\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eIntegrated Sliding Bug Screen\u003c\/strong\u003e – Enjoy fresh air without insects entering your van\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eOEM-Style Construction\u003c\/strong\u003e – Factory-quality appearance and fitment for Sprinter vans\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSmooth Operation\u003c\/strong\u003e – Precision-engineered slider mechanism for effortless opening and closing\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003ch3\u003ePerfect For Sprinter Conversions\u003c\/h3\u003e\n\u003cp\u003eThis half-slider window stands out from traditional designs with its unique flush-closing mechanism. Unlike standard slider windows that leave an indent when closed, this window closes completely flush with the rest of the frame for a clean, seamless appearance. The single-pane tempered glass provides excellent clarity and meets all safety standards, while the integrated sliding bug screen lets you enjoy ventilation without unwanted visitors. Ideal for galley areas, sleeping quarters, or anywhere you want controlled airflow with a premium aesthetic.\u003c\/p\u003e\n\u003ch3\u003eSpecifications\u003c\/h3\u003e\n\u003cul\u003e\n\u003cli\u003eCompatibility: Mercedes Sprinter vans\u003c\/li\u003e\n\u003cli\u003eDesign: OEM-style half-slider with flush-close mechanism\u003c\/li\u003e\n\u003cli\u003eGlass: Single-pane tempered safety glass\u003c\/li\u003e\n\u003cli\u003eBug Screen: Integrated sliding screen included\u003c\/li\u003e\n\u003cli\u003eOperation: Smooth sliding mechanism\u003c\/li\u003e\n\u003cli\u003eFitment: Flush-close design eliminates traditional indent\u003c\/li\u003e\n\u003cli\u003eInstallation: Professional installation recommended\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003ch3\u003eWhat's Included\u003c\/h3\u003e\n\u003cp\u003eComplete OEM-style half-slider window assembly with integrated sliding bug screen, weather sealing, and installation hardware for professional-grade fitment in your Mercedes Sprinter.\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eSave $100 during our New Year Sale.\u003c\/strong\u003e\u003c\/p\u003e","published_at":"2024-02-13T16:18:41-08:00","created_at":"2024-02-13T16:18:41-08:00","vendor":"Tec Vanlife","type":"","tags":[],"price":53500,"price_min":53500,"price_max":53500,"available":true,"price_varies":false,"compare_at_price":53500,"compare_at_price_min":53500,"compare_at_price_max":53500,"compare_at_price_varies":false,"variants":[{"id":42988856737957,"title":"Driver Side | Behind The Driver Seat","option1":"Driver Side | Behind The Driver Seat","option2":null,"option3":null,"sku":"I-WI-T-HS-DS","requires_shipping":true,"taxable":true,"featured_image":{"id":42869699018917,"product_id":8403375161509,"position":3,"created_at":"2025-10-24T14:20:42-07:00","updated_at":"2025-11-13T21:54:57-08:00","alt":null,"width":6000,"height":4000,"src":"\/\/tecvanlife.com\/cdn\/shop\/files\/2C6A4662.jpg?v=1763099697","variant_ids":[42988856737957]},"available":true,"name":"Mercedes Sprinter OEM Style Half-Slider Window - Driver Side | Behind The Driver Seat","public_title":"Driver Side | Behind The Driver Seat","options":["Driver Side | Behind The Driver Seat"],"price":53500,"weight":0,"compare_at_price":53500,"inventory_management":"shopify","barcode":"704487895998","featured_media":{"alt":null,"id":33486247854245,"position":4,"preview_image":{"aspect_ratio":1.5,"height":4000,"width":6000,"src":"\/\/tecvanlife.com\/cdn\/shop\/files\/2C6A4662.jpg?v=1763099697"}},"requires_selling_plan":false,"selling_plan_allocations":[],"quantity_rule":{"min":1,"max":null,"increment":1}},{"id":42988856770725,"title":"Passenger Side | Sliding Door","option1":"Passenger Side | Sliding Door","option2":null,"option3":null,"sku":"I-WI-T-HS-PS","requires_shipping":true,"taxable":true,"featured_image":{"id":42869697937573,"product_id":840337