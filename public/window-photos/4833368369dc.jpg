<header-actions
  
>
  
    
    <div
      class="account-button header-actions__action color-scheme-1"
    >
      <shopify-store store-domain="https://tecvanlife.com" country="US" language="en"></shopify-store>
<shopify-account
        menu="customer-account-main-menu"
        
      >
        
          <span
            slot="signed-out-avatar"
            class="account-button__text header-actions__text-style hidden"
          >
            Account
          </span>

          <span
            slot="signed-out-avatar"
            class=""
            aria-hidden="true"
          >
            
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="15"
    height="17"
    viewBox="0 0 15 17"
    fill="none"
    slot="signed-out-avatar"
    class="account-button__icon"
  >
    <path
      stroke="currentColor"
      stroke-linejoin="round"
      stroke-width="var(--icon-stroke-width)"
      d="M10.375 3.813a3.063 3.063 0 1 1-6.125 0 3.063 3.063 0 0 1 6.125 0ZM7.313 9.5c-3.667 0-6.24 2.691-6.563 6.125h13.125C13.552 12.191 10.979 9.5 7.312 9.5Z"
    />
  </svg>

          </span>
        
      </shopify-account>
    </div>
  

  
