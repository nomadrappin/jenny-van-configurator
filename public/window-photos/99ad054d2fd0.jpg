var retainful_localize_data = {"popup_json":"[{\"uuid\":\"019d2528-d892-7aa0-8959-2d496f23dac2\",\"name\":\"Sitewide Email Capture | Newsletter\",\"status\":\"active\",\"version\":1,\"createdAt\":\"2026-03-25T13:22:07.123Z\",\"updatedAt\":\"2026-04-13T19:25:01.507Z\",\"organization_uuid\":\"019caedd-f06f-7fe1-a17c-b2872a5959a9\",\"data\":{\"type\":\"exit_intent\",\"segmentUUIDs\":[\"019cb26c-c732-7063-88cd-d389b0de5b19\"],\"segmentNames\":[],\"triggers\":{\"type\":\"exit\",\"primary\":{\"type\":\"exit\",\"enabled\":true},\"secondary\":[]},\"targeting\":{\"pages\":{\"type\":\"\",\"rules\":[]},\"audience\":{\"type\":\"\",\"devices\":[]},\"location\":{\"type\":\"\",\"includedCountries\":[],\"excludedCountries\":[]},\"schedule\":{\"type\":\"\",\"start\":null,\"hasEnd\":false,\"end\":null,\"timeZone\":\"UTC\"}},\"frequency\":{\"type\":\"once_per_visitor\",\"limit\":{\"count\":1,\"period\":\"forever\"}},\"content\":{\"start\":{\"heading\":\"\",\"description\":\"\",\"buttonText\":\"Subscribe\",\"placeholder\":\"Your email address\",\"imagePosition\":\"left\",\"secondaryAction\":{\"enabled\":false},\"disclaimer\":{\"enabled\":false},\"height\":350,\"customCss\":\"#retainful-popup-wrapper .retainful-popup-content {\\n  display: flex;\\n  flex-direction: inherit;\\n  justify-content: center;\\n}\\n\\n\\n\",\"descriptionCustomCss\":\".retainful-popup-description {\\n  font-size:13px !important;\\n  color:black !important\\n}\",\"headingCustomCss\":\".retainful-popup-heading {\\n  \\n}\",\"width\":550,\"useCustomHtml\":true,\"customHtml\":\"\\n\u003Cstyle\u003E\\n  * { box-sizing: border-box; }\\n  \\n  .rtf-semi-circle {\\n    position: fixed !important;\\n    left: 50%;\\n    transform: translateX(-50%);\\n    display: flex;\\n    padding: 30px 10px 0;\\n    background-color: #d7d3bf; \\/* Nomadic beige *\\/\\n    border-radius: 1000px;\\n    overflow-x: visible;\\n    overflow-y: visible;\\n    animation: rtf-slideInUp 0.8s 0.6s cubic-bezier(0.4, 0, 0.2, 1) both;\\n  }\\n  \\n  \\/* Mobile: 550x550, bottom -275px = hide bottom half for true semi-circle *\\/\\n  @media (max-width: 1023px) {\\n    .rtf-semi-circle {\\n      width: 550px;\\n      height: 550px;\\n      bottom: -275px;\\n      flex-direction: column;\\n      align-items: center;\\n      justify-content: flex-start;\\n    }\\n  }\\n  \\n  \\/* Desktop: 1200x1200, bottom -1020px *\\/\\n  @media (min-width: 1024px) {\\n    .rtf-semi-circle {\\n      width: 1200px;\\n      height: 1200px;\\n      bottom: -950px;\\n      flex-direction: row;\\n      align-items: flex-start;\\n      justify-content: center;\\n    }\\n  }\\n  \\n  @keyframes rtf-slideInUp {\\n    from {\\n      transform: translate3d(-50%, 100%, 0);\\n      visibility: visible;\\n    }\\n    to {\\n      transform: translate3d(-50%, 0, 0);\\n    }\\n  }\\n  \\n  .rtf-close-btn {\\n    position: absolute;\\n    left: 50%;\\n    top: 20px;\\n    transform: translateX(calc(-50% + 150px));\\n    width: 50px;\\n    height: 50px;\\n    display: flex;\\n    align-items: center;\\n    justify-content: center;\\n    border-radius: 100px;\\n    background-color: rgba(215, 211, 191, 0.97);\\n    box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);\\n    border: none;\\n    cursor: pointer;\\n    padding: 0;\\n    z-index: 10;\\n    animation: rtf-fadeIn 0.7s 1s both;\\n  }\\n  @media (min-width: 1024px) {\\n    .rtf-close-btn {\\n      top: 30px;\\n      transform: translateX(calc(-50% + 250px));\\n    }\\n  }\\n  @keyframes rtf-fadeIn {\\n    from { opacity: 0; }\\n    to { opacity: 1; }\\n  }\\n  .rtf-close-btn svg {\\n    width: 28px;\\n    height: 28px;\\n    stroke: #251d15;\\n  }\\n  \\n  \\/* Content area *\\/\\n  .rtf-content {\\n    display: flex;\\n    flex-direction: column;\\n    align-items: center;\\n    justify-content: center;\\n    max-width: 350px;\\n    padding-top: 10px;\\n  }\\n  @media (min-width: 1024px) {\\n    .rtf-content {\\n      max-width: 500px;\\n      align-items: center;\\n      justify-content: flex-start;\\n      padding-top: 30px;\\n    }\\n  }\\n  \\n  .rtf-logo {\\n    width: 75px;\\n    margin-bottom: 25px;\\n  }\\n  @media (min-width: 1024px) {\\n    .rtf-logo { width: 90px; margin-bottom: 30px; }\\n  }\\n  \\n  .rtf-heading {\\n    font-family: 'DM Sans', Arial, sans-serif;\\n    font-weight: 700;\\n    font-size: 34px;\\n    line-height: 1.1;\\n    text-align: center;\\n    color: #251d15;\\n    margin: 0;\\n  }\\n  @media (min-width: 1024px) {\\n    .rtf-heading { font-size: 40px; }\\n  }\\n  \\n  .rtf-subtitle {\\n    font-family: 'DM Sans', Arial, sans-serif;\\n    font-weight: 400;\\n    font-size: 16px;\\n    line-height: 1.25;\\n    text-align: center;\\n    color: #666666;\\n    margin-top: 10px;\\n  }\\n  @media (min-width: 1024px) {\\n    .rtf-subtitle { font-size: 18px; }\\n  }\\n  \\n  \\/* Form *\\/\\n  .retainful-popup-form {\\n    display: flex !important;\\n    flex-direction: column !important;\\n    gap: 10px !important;\\n    margin-top: 22px;\\n    width: 260px;\\n  }\\n  @media (min-width: 1024px) {\\n    .retainful-popup-form {\\n      margin-top: 24px;\\n      width: 320px;\\n      gap: 10px !important;\\n    }\\n  }\\n  \\n  .rtf-input {\\n    width: 100%;\\n    padding: 14px 20px;\\n    font-size: 15px;\\n    font-family: 'DM Sans', Arial, sans-serif;\\n    border: 1px solid #ccc;\\n    border-radius: 4px;\\n    background: #fff;\\n    color: #251d15;\\n  }\\n  .rtf-input::placeholder { color: rgba(37, 29, 21, 0.5); }\\n  \\n  .rtf-btn {\\n    width: 100%;\\n    padding: 18px 22px;\\n    font-size: 16px;\\n    font-weight: 600;\\n    font-family: 'DM Sans', Arial, sans-serif;\\n    text-transform: uppercase;\\n    letter-spacing: normal;\\n    color: #fff;\\n    background-color: #251d15;\\n    border: none;\\n    border-radius: 4px;\\n    cursor: pointer;\\n    transition: background 0.3s ease;\\n    position: relative;\\n  }\\n  .rtf-btn:hover { background-color: black; }\\n  \\/* Spinner when loading - engine adds loading=\\\"true\\\" to .retainful-btn on submit *\\/\\n  .rtf-btn[loading=\\\"true\\\"] {\\n    pointer-events: none;\\n    opacity: 0.8;\\n    padding-right: 44px !important;\\n  }\\n  .rtf-btn[loading=\\\"true\\\"]::after {\\n    content: '';\\n    position: absolute;\\n    right: 14px;\\n    top: 50%;\\n    transform: translateY(-50%);\\n    width: 18px;\\n    height: 18px;\\n    border: 2px solid currentColor;\\n    border-right-color: transparent;\\n    border-top-color: transparent;\\n    border-radius: 50%;\\n    animation: rtf-spin 0.75s linear infinite;\\n    box-sizing: border-box;\\n  }\\n  @keyframes rtf-spin {\\n    0% { transform: translateY(-50%) rotate(0deg); }\\n    100% { transform: translateY(-50%) rotate(360deg); }\\n  }\\n  @media (min-width: 1024px) {\\n    .rtf-btn { font-size: 18px; }\\n  }\\n\u003C\\/style\u003E\\n\u003Cdiv class=\\\"rtf-semi-circle\\\"\u003E\\n  \u003Cbutton type=\\\"button\\\" class=\\\"retainful-popup-close rtf-close-btn\\\" aria-label=\\\"Close\\\"\u003E\\n    \u003Csvg xmlns=\\\"http:\\/\\/www.w3.org\\/2000\\/svg\\\" viewBox=\\\"0 0 21 21\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"2\\\"\u003E\\n      \u003Cline x1=\\\"3\\\" y1=\\\"3\\\" x2=\\\"18\\\" y2=\\\"18\\\"\\/\u003E\\n      \u003Cline x1=\\\"18\\\" y1=\\\"3\\\" x2=\\\"3\\\" y2=\\\"18\\\"\\/\u003E\\n    \u003C\\/svg\u003E\\n  \u003C\\/button\u003E\\n  \\n  \u003Cdiv class=\\\"rtf-content\\\"\u003E\\n    \u003Cimg class=\\\"rtf-logo\\\" src=\\\"https:\\/\\/form-assets.mailchimp.com\\/images\\/accounts\\/163908834\\/b7d4e62cc78e20ca347f523857b16322.webp\\\" alt=\\\"Logo\\\" \\/\u003E\\n    \u003Ch2 class=\\\"rtf-heading\\\"\u003EJoin The Nomadic Supply Company Community\u003C\\/h2\u003E\\n    \u003Cp class=\\\"rtf-subtitle\\\"\u003EGet updates on new products and community news\u003C\\/p\u003E\\n    \\n    \u003Cform class=\\\"retainful-popup-form\\\" data-popup-id=\\\"{{popupUuid}}\\\"\u003E\\n      \u003Cinput type=\\\"email\\\" name=\\\"email\\\" class=\\\"rtf-input\\\"