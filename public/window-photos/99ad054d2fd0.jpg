:hover { background: black; }\\n  @media (min-width: 1024px) {\\n    .rtf-btn { font-size: 18px; }\\n  }\\n\u003C\\/style\u003E\\n\\n\u003Cdiv class=\\\"rtf-semi-circle\\\"\u003E\\n  \u003Cbutton type=\\\"button\\\" class=\\\"retainful-popup-close rtf-close-btn\\\" aria-label=\\\"Close\\\"\u003E\\u00d7\u003C\\/button\u003E\\n  \u003Cdiv class=\\\"rtf-content\\\"\u003E\\n    \u003Cimg class=\\\"rtf-logo\\\" src=\\\"https:\\/\\/form-assets.mailchimp.com\\/images\\/accounts\\/163908834\\/b7d4e62cc78e20ca347f523857b16322.webp\\\" alt=\\\"Logo\\\" \\/\u003E\\n    \u003Ch2 class=\\\"rtf-heading\\\"\u003EWelcome to the club!\u003C\\/h2\u003E\\n    \u003Cp class=\\\"rtf-subtitle\\\"\u003EYou're officially in the VIP club! Keep an eye on your inbox.\u003C\\/p\u003E\\n    \u003Cbutton type=\\\"button\\\" class=\\\"rtf-btn retainful-btn\\\" data-action=\\\"close\\\"\u003EBack to site\u003C\\/button\u003E\\n  \u003C\\/div\u003E\\n\u003C\\/div\u003E\"},\"teaserWidget\":{\"buttonText\":\"Join the Community\",\"showIcon\":true,\"iconId\":\"envelope\",\"customCss\":\".retainful-teaser {\\n  \\/* Add your custom styles below *\\/\\n  \\/* Example: *\\/\\n  \\/* font-size: 16px; *\\/\\n  \\/* padding: 20px; *\\/\\n}\"},\"sidebar_widget\":{\"buttonText\":\"Get 10% OFF\"},\"form\":{\"fields\":[{\"type\":\"email\",\"name\":\"email\",\"label\":\"Email\",\"placeholder\":\"Your email address\",\"required\":true,\"enabled\":true,\"fontFamily\":\"Helvetica\",\"fontSize\":\"14px\",\"fontWeight\":\"400\",\"bold\":false,\"italic\":false,\"underline\":false,\"textColor\":\"#1a1a1a\",\"customCss\":\"\"}]},\"actions\":{\"primary\":{\"enabled\":true,\"text\":\"GET 15% OFF\",\"type\":\"submit\"}},\"footer\":{\"text\":\"\u003Cdiv\u003E\u003Cbr\u003E\u003C\\/div\u003E\"},\"media\":{\"position\":\"left\"}},\"design\":{\"colors\":{\"background\":\"#fffcfc\",\"text\":{\"primary\":\"#000000\",\"secondary\":\"#555555\"},\"buttons\":{\"primary\":{\"background\":\"#000000\",\"text\":\"#ffffff\",\"hover\":\"#