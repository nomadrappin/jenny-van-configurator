<meta name="generator" content="Advanced Coupons for WooCommerce Free v4.7.2" />    <style>
        /* ── Brand palette ──────────────────────────────────────
           Navy:   #1e2d3d   (logo background / dark anchor)
           Tan:    #c9a96e   (compass / khaki accent)
           Orange: #e07b2a   (CTA buttons, warm accent)
        ───────────────────────────────────────────────────── */

        /* Wrapper: price + badge on the same line */
        .map-price-wrap {
            display: inline-flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .map-price-advertised {
            display: inline-block;
        }

        /* ── Badge ─────────────────────────────────────────── */
        .map-price-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #1e2d3d;
            color: #c9a96e;
            border: 1.5px solid #c9a96e;
            border-radius: 999px;
            padding: 5px 13px 5px 10px;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            line-height: 1.4;
            white-space: nowrap;
            cursor: pointer;
            transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
            user-select: none;
        }

        .map-price-badge:hover,
        .map-price-badge:focus {
            background: #e07b2a;
            color: #fff;
            border-color: #e07b2a;
            box-shadow: 0 2px 10px rgba(224, 123, 42, 0.35);
            outline: none;
        }

        .map-price-badge__icon,
        .map-price-badge__info {
            flex-shrink: 0;
        }

        /* Mobile: stack below price */
        @media (max-width: 480px) {
            .map-price-wrap {
                flex-direction: column;
                align-items: flex-start;
                gap: 8px;
            }
        }

        /* ── Archive / loop badge ─────────────────────────────── */
        .map-price-loop-badge {
            display: block;
            background: #4b5945;
            color: #fff;
            border-radius: 3px;
            padding: 4px 10px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.01em;
            line-height: 1.45;
            white-space: normal;
            margin-top: 6px;
            text-decoration: none;
            transition: background 0.15s ease;
        }
        .map-price-loop-badge:hover { background: #3a4535; color: #fff; }

        /* ── Modal overlay ─────────────────────────────────── */
        .map-price-modal {
            position: fixed;
            inset: 0;
            z-index: 99999;
            display: none; /* shown via JS as flex */
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        .map-price-modal__overlay {
            position: absolute;
            inset: 0;
            background: rgba(15, 22, 32, 0.72);
            backdrop-filter: blur(3px);
            cursor: pointer;
        }

        /* ── Modal box ─────────────────────────────────────── */
        .map-price-modal__box {
            position: relative;
            z-index: 1;
            background: #fff;
            border-radius: 12px;
            max-width: 480px;
            width: 100%;
            padding: 36px 32px 28px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            text-align: center;
            animation: mapModalIn 0.22s ease;
        }

        @keyframes mapModalIn {
            from { opacity: 0; transform: translateY(16px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0)    scale(1);    }
        }

        .map-price-modal__close {
            position: absolute;
            top: 12px;
            right: 14px;
            background: none;
            border: none;
            font-size: 1.5rem;
            line-height: 1;
            color: #999;
            cursor: pointer;
            padding: 4px 8px;
            border-radius: 4px;
            transition: color 0.15s, background 0.15s;
        }

        .map-price-modal__close:hover {
            color: #1e2d3d;
            background: #f0f0f0;
        }

        .map-price-modal__icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 60px;
            height: 60px;
            background: #1e2d3d;
            border-radius: 50%;
            color: #c9a96e;
            margin: 0 auto 18px;
        }

        .map-price-modal__box h2 {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e2d3d;
            margin: 0 0 14px;
            line-height: 1.3;
        }

        .map-price-modal__box p {
            font-size: 0.93rem;
            color: #444;
            line-height: 1.6;
            margin: 0 0 12px;
        }

        .map-price-modal__sub {
            font-size: 0.82rem !important;
            color: #888 !important;
            border-top: 1px solid #eee;
            padding-top: 12px;
            margin-top: 4px !important;
        }

        .map-price-modal__cta {
            display: inline-block;
            margin-top: 18px;
            background: #4b5945;
            color: #fff;
            border: none;
            border-radius: 999px;
            padding: 12px 28px;
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            cursor: pointer;
            transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
        }

        .map-price-modal__cta:hover:not(:disabled) {
            background: #d7d3bf;
            color: #272626;
            box-shadow: 0 4px 14px rgba(0,0,0,0.15);
        }

        .map-price-modal__cta:disabled {
            opacity: 0.7;
            cursor: wait;
        }
    </style>
