}
/* MOBILE FILTER BUTTON — Shortcode Pages */
@media (max-width: 800px) {
    .nv-sidebar-wrap:has(.wfpHideButton) {
        padding: 0 !important;
        margin-bottom: 0 !important;
        flex-grow: 0 !important;
        flex-basis: 100% !important;
        max-height: 50px !important;
    }
    .nv-sidebar-wrap:has(.wfpHideButton) #secondary {
        margin-top: -30px !important;
    }
    .nv-sidebar-wrap:has(.wfpHideButton) .widget.widget_block {
        margin-bottom: 0 !important;
    }
    .nv-sidebar-wrap:has(.wfpHideButton) .wfpHideButton {
        width: calc(100% - 30px) !important;
        max-width: none !important;
    }
}

/* MOBILE FILTER ICON — Native WooCommerce Pages */
@media (max-width: 800px) {
    .nv-woo-filters {
        margin-bottom: 20px !important;
    }
}		</style>
		
