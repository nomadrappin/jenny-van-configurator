    <script>
    (function () {
        'use strict';

        // ── Build and inject modal HTML directly into <body> ──
        var modalHTML = [
            '<div class="map-price-modal" id="map-price-modal" role="dialog" aria-modal="true" aria-labelledby="map-modal-title" style="display:none;">',
                '<div class="map-price-modal__overlay" onclick="mapPriceCloseModal()"></div>',
                '<div class="map-price-modal__box">',
                    '<button class="map-price-modal__close" onclick="mapPriceCloseModal()" aria-label="Close">&times;</button>',
                    '<div class="map-price-modal__icon">',
                        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="32" height="32">',
                            '<path d="M21.41 11.58l-9-9A2 2 0 0 0 11 2H4a2 2 0 0 0-2 2v7a2 2 0 0 0 .59 1.42l9 9A2 2 0 0 0 13 22a2 2 0 0 0 1.41-.59l7-7A2 2 0 0 0 22 13a2 2 0 0 0-.59-1.42zM6.5 8a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>',
                        '</svg>',
                    '</div>',
                    '<h2 id="map-modal-title">Why Can\'t We Show Our Price?</h2>',
                    '<p>The manufacturer of this product requires all authorized retailers to follow a <strong>Minimum Advertised Price (MAP)</strong> policy. This means we are not permitted to publicly display our actual selling price on the product page.</p>',
                    '<p>The good news? Our price is <strong>below</strong> the advertised price shown above — and you\'ll see exactly what you\'ll pay the moment you add this item to your cart. No games, no bait-and-switch.</p>',
                    '<p class="map-price-modal__sub">Nomadic Supply Company is an authorized dealer fully committed to offering you the best possible price within our agreement with the manufacturer.</p>',
                    '<button class="map-price-modal__cta" onclick="mapPriceAddToCart()">Add to Cart &amp; See Our Price</button>',
                '</div>',
            '</div>'
        ].join('');

        // Append once DOM is ready
        function injectModal() {
            if ( document.getElementById('map-price-modal') ) return; // already exists
            var div = document.createElement('div');
            div.innerHTML = modalHTML;
            document.body.appendChild(div.firstChild);
        }

        if ( document.readyState === 'loading' ) {
            document.addEventListener('DOMContentLoaded', injectModal);
        } else {
            injectModal();
        }

        // Escape key to close
        document.addEventListener('keydown', function(e) {
            if ( e.key === 'Escape' ) { mapPriceCloseModal(); }
        });
    })();

    // ── Global open/close functions (called via inline onclick) ──
    function mapPriceOpenModal() {
        var modal = document.getElementById('map-price-modal');
        if ( !modal ) return;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        var closeBtn = modal.querySelector('.map-price-modal__close');
        if ( closeBtn ) { setTimeout(function(){ closeBtn.focus(); }, 50); }
    }

    function mapPriceCloseModal() {
        var modal = document.getElementById('map-price-modal');
        if ( !modal ) return;
        modal.style.display = 'none';
        document.body.style.overflow = '';
    }

    function mapPriceAddToCart() {
        // Update button to show loading state
        var ctaBtn = document.querySelector('.map-price-modal__cta');
        if ( ctaBtn ) {
            ctaBtn.textContent = 'Adding to Cart\u2026';
            ctaBtn.disabled = true;
        }

        // Find the WooCommerce add-to-cart form on the page
        var form = document.querySelector('form.cart');
        if ( !form ) {
            // Fallback: just close modal and scroll to ATC button
            mapPriceCloseModal();
            var btn = document.querySelector('.single_add_to_cart_button');
            if ( btn ) btn.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }

        // Get product ID and quantity from the form
        var productId  = form.querySelector('[name="product_id"], [name="add-to-cart"]');
        var qty        = form.querySelector('[name="quantity"]');
        var productVal = productId ? productId.value : '';
        var qtyVal     = qty ? qty.value : '1';

        // Build form data
        var data = new FormData(form);
        data.set('add-to-cart', productVal);
        data.set('quantity', qtyVal);

        // Submit via fetch to WC AJAX add-to-cart endpoint
        fetch( form.action || window.location.href, {
            method: 'POST',
            body: data,
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            redirect: 'follow'
        })
        .then(function() {
            // Redirect to cart page to reveal the discounted price
            window.location.href = 'https://nomadicsupply.com/cart/';
        })
        .catch(function() {
            // On any error, fall back to a normal form submit which WC handles fine
            form.submit();
        });
    }
    </script>
    
