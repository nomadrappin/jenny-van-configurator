    <script>
        jQuery(function($){
            $( "form#wpforms-form-105871" ).click(function(){
                var selectedval = $( ".wpforms-form input[type='radio']:checked" ).val();
                if(selectedval == "Yes"){
                    window.location = "/my-account/orders/";
                }
                if(selectedval == "No"){
                    $( ".wpforms-submit" ).addClass( "show-submit" );
                }
            });
        });
    </script>
        <script>
    (function() {
        function fixCaretButtons() {
            document.querySelectorAll('button.caret-wrap').forEach(function(btn) {
                Array.from(btn.childNodes).forEach(function(node) {
                    if (node.nodeType === 3 && node.nodeValue.trim() !== '') {
                        btn.removeChild(node);
                    }
                });
            });
        }
        // Run immediately
        fixCaretButtons();
        // Run on any DOM mutations (catches JS-injected buttons)
        var observer = new MutationObserver(fixCaretButtons);
        observer.observe(document.body, { childList: true, subtree: true });
        // Also run after full page load
        window.addEventListener('load', fixCaretButtons);
    })();
    </script>
