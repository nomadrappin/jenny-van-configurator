			/* Store Notice */
body {
	display: grid;
}
.woocommerce-store-notice, p.demo_store {
	position: static;
	order: -1;
	background-color: var(--nv-primary-accent);
	padding: 5px 0;
	color: var(--nv-text-dark-bg);
}
.woocommerce-store-notice__dismiss-link {
	display: none;
}
.page-id-19 .woocommerce-store-notice, .page-id-20 .woocommerce-store-notice {
	display: none !important;
}
/* Breadcrumbs */
.woocommerce-breadcrumb {
	margin-top: -30px !important;
	padding-top: 0 !important;
	padding-left: 15px !important;
	white-space: normal !important;
}
.woocommerce .woocommerce-breadcrumb a {
	color: var(--nv-primary-accent);
}
/* Cart: Message */
.fc-wrapper #order_review table.woocommerce-checkout-review-order-table tfoot td {
	text-align: left !important;
}
/* Cart: Neve Payment Icons */
.nv-payment-cart-total {
	margin-bottom: 25px;
	text-align: center;
}
/* Cart: Gift Card */
#pwgc-redeem-gift-card-container {
	padding: 35px 0 20px 0;
}
/* Cart: Order Summary Font */
.woocommerce table.shop_table tfoot th {
	font-weight: 400;
}
/* Cart: Hide Mini Cart When Empty */
.cart-is-empty .nv-nav-cart.widget {
	display: none !important;
}
/* Checkout: Store Credit */
.acfw-accordions {
	margin: 25px 0 35px 0;
}
.acfw-form-control-label {
	margin-top: -15% !important;
}
/* Checkout: Fix Stripe ACH Icon */
.fc-wrapper #payment ul.payment_methods>li.wc_payment_method>label .payment-method__label-icon img {
	width: 50px;
}
/* Checkout: Notices */
.woocommerce .woocommerce-message, .woocommerce-page .woocommerce-message, .cart-empty.woocommerce-info {
	background: var(--nv-dark-bg);
	color: #fff;
	border-radius: 20px;
}
/* Checkout: Gateway Details */
.wc-stripe-gateway-desc {
	margin-bottom: 25px;
}
/* Checkout: Terms */
.woocommerce-terms-and-conditions-checkbox-text {
	font-size: .85em;
}
.woocommerce-terms-and-conditions-wrapper {
	background-color: #f3f3f3;
	border-radius: 5px;
	padding: 10px !important;
}
/* Checkout: Tax Exemption */
#tax_exemption_message_div {
	margin-top: 25px;
}
/* Payments: CSS Highlight */
.highlight {
	background-image: linear-gradient(to right, #F27121cc, #E94057cc, #8A2387cc);
	border-radius: 6px;
	padding: 3px 6px;
}
/* Product Page: Stripe Climate */
.mission {
	border: 2px solid;
	border-radius: 20px;
	background-color: var(--nv-secondary-accent);
	padding: 10px;
	text-align: center;
	margin-bottom: 25px;
}
.mission a {
	color: var(--nv-text);
}
/* Product Page: Short Description */
.woocommerce-product-details__short-description a {
	--linkdeco: underline;
}
/* Product Page: H2 Spacing After Lists */
.woocommerce-Tabs-panel--description ul + h2,
.woocommerce-Tabs-panel--description ol + h2 {
	margin-top: 1.5em;
}
/* Product Page: Add to Cart Success */
.wc-block-components-notice-banner.is-success {
	background-color: var(--nv-dark-bg) !important;
	margin-bottom: 30px;
}
/* Product Page: Youtube Video */
.nv-iframe-embed {
	margin-bottom: 25px;
}
/* Product Page: Stock Quantity */
.woocommerce div.product .stock {
	color: var(--nv-text-color);
}
.woocommerce div.product p.stock {
	font-size: 1.25em;
	font-weight: 700;
}
/* Product Page Tariff Notice */
table.extra-options.thwepo_tariff {
	border: 2px solid !important;
	padding: 10px;
	border-radius: 20px;
	background-color: var(--nv-secondary-accent) !important;
}
/* Product Page Notices */
.woocommerce-page .woocommerce-error {
	border: 2px solid;
	border-radius: 20px;
	color: var(--nv-text-color);
	font-size: 15px;
}
/* Product Page Discontinued Notice */
.woocommerce div.product p.stock {
    color: var(--nv-text-color);
    font-size: 1.25em;
    font-weight: 700;
}
.woocommerce div.product p.stock.out-of-stock {
    margin-bottom: 10px;
}
.woocommerce div.product p.stock .woocommerce-error {
    font-weight: normal;
    margin-bottom: 0 !important;
}
@media only screen and (max-width: 600px) {
	.woocommerce .woocommerce-error {
		padding-left: 10px !important;
	}
}
/* Product Page Hide Discontinued $0.00 Price */
.woocommerce div.product:has(p.stock.out-of-stock .woocommerce-error) p.price {
    display: none;
}
/* Hide the circular exclamation point icon */
span.woocommerce-error::before {
	display: none !important;
}
span.woocommerce-error {
	padding-left: 20px;
}
/* Product Page: CPS */
.btn-offer {
	height: 77px !important;
}
.button-cps:hover {
	border-color: var(--nv-primary-accent) !important;
	box-shadow: 0 0 0 1px inset var(--nv-primary-accent) !important;
	background-color: var(--nv-primary-accent) !important;
}
.selected {
	box-shadow: 0 0 0 1px inset var(--nv-primary-accent) !important;
	background-color: var(--nv-secondary-accent) !important;
	color: var(--nv-text-color) !important;
}
/* Product Page: Meta */
.product_meta {
	padding-top: 30px;
}
.product_meta>span {
	margin-top: 0;
}
/* Product Page: Brand */
.pwb-single-product-brands {
	float: left;
	padding-right: 20px;
	margin-top: 20px;
}
.pwb-single-product-brands img {
	max-height: 120px;
	width: auto;
	background-color: var(--nv-primary-accent);
	padding: 5px;
	border-radius: 25px;
}
.woocommerce.single .entry-summary>form.cart {
	margin-bottom: 0;
}
/* Product Page: Tabs */
.woocommerce-tabs {
	margin-top: 0;
}
.woocommerce #content div.product .woocommerce-tabs ul.tabs {
	background: var(--nv-primary-accent);
	border-radius: 20px;
	padding-left: 20px;
}
.woocommerce div.product .woocommerce-tabs ul.tabs li.active a {
	color: var(--nv-text-dark-bg);
}
.woocommerce div.product .woocommerce-tabs ul.tabs li a {
	color: var(--nv-secondary-accent);
}
.woocommerce div.product .woocommerce-tabs ul.tabs li a:hover {
	text-decoration: underline;
	color: var(--nv-text-dark-bg);
}
/* Product Page: Waitlist */
.xoo-wl-btn-container {
	margin-top: 25px;
}
/* Product Page: Remove Wishlist */
.outofstock .sp-wl-wrap {
	display: none;
}
/* Product Page: Upsells */
section.up-sells.upsells.products {
	background-color: #ffffff;
	padding: 20px;
	border: 1px solid #ddd;
	margin: 20px 0;
	border-radius: 8px;
	clear: both;
	max-width: var(--wp--style--global--wide-size);
}
.woocommerce .nv-shop ul.products:not(.tns-slider) {
	margin-top: 25px;
	margin-bottom: 0;
}
/* Product Page: YUKO */
.yuko-reviews-product-widget-iframe-container {
	background-color: #f9f9f9;
	padding: 20px;
	border: 1px solid #ddd;
	margin: 20px 0;
	border-radius: 8px;
	clear: both;
	max-width: var(--wp--style--global--wide-size);
}
/* Product Category: Heading */
.nv-card-content-wrapper, .woocommerce-loop-category__title {
	text-align: center;
}
/* Product Category Top Spacing */
.nv-woo-filters {
	margin-bottom: 0;
}
/* Product Category Pagination */
.woocommerce-pagination {
	margin-bottom: 25px;
}
/* Product Category Result Count */
.woocommerce-result-count {
	display: none;
}
/* Footer: Main Row Top Spacing */
.footer-main-inner {
	padding-top: 30px;
}
/* Footer: Widget Spacing */
.widget {
	margin-bottom: 10px !important;
}

/* Footer: Social Icons */
.social-menu {
	display: flex;
	list-style-type: none;
}
.social-menu i {
	color: var(--nv-text-color);
	width: 50px;
	height: 50px;
	border-radius: 50%;
	font-size: 25px;
	margin-right: 10px;
	transition: all 0.2s ease-in-out;
	display: flex;
	justify-content: center;
}
.social-menu i:before {
	display: flex;
	flex-flow: row nowrap;
	align-items: center;
}
.social-menu a {
	text-decoration: none;
}
.fa-youtube, .fa-instagram, .fa-linkedin, .fa-facebook {
	background: var(--nv-secondary-accent);
}
/* Fluid Checkout Notice */
.fc-wrapper .cart_item .cart-item__notification-message {
	color: var(--nv-text-color);
	background-color: var(--nv-c-1);
}
.fc-coupon-code-messages {
	padding-top: 25px;
}
/* Fluid Checkout Shipping */
.fc-section-title--shipping:after {
	content: ' Estimate';
}
/* Route */
.route-div {
	background-color: #fcfcfc;
	padding: 10px;
	background: var(--nv-dark-bg);
	border-radius: 5px;
	color: var(--nv-text-dark-bg);
}
.pw-container {
	background-color: #f5f5f5;
	border-radius: 5px;
	padding: 10px !important;
}
.pw-route-protection {
	justify-content: left !important;
	padding: 0 !important;
}
.pw-route-protection .pw-container:not(.legacy) {
	max-width: 425px !important;
}
#RouteWidget:after {
	content: "Protect your packages with a guaranteed refund or replacement if your packages are lost, damaged, or stolen. If you decline Route Package Protection, you are responsible for all lost, damaged, or stolen packages.";
	white-space: pre-wrap;
}
#RouteWidget {
	font-size: .85em;
	padding-bottom: 10px;
	margin-top: 20px;
}
/* My Account Login Page */
.page-id-21 .nv-content-wrap {
	padding-top: 30px;
}
/* 404 Page Fix */
.page-id-37513 .nv-page-title-wrap .nv-page-title {
	display: none !important;
}
/* Builder Directory */
.branding-footer {
	display: none !important;
}
/* SliceWP Affiliate Page */
#slicewp-affiliate-register-form {
	padding-bottom: 80px;
}
/* Extra Product Options */
.extra-options.thwepo_default_style td.value {
	padding: 0;
}
.extra-options.thwepo_default_style label.label-tag {
	padding: 0;
}
.extra-options.thwepo_default_style .thwepo-input-field.input-checkbox {
	margin-top: 0;
}
.extra-options h3 {
	margin-bottom: 0;
}
label.radio.thwepo-valign {
	margin-bottom: 0 !important;
}
.extra-options td.section-title {
	padding: 0 !important;
}
.label-tag {
	font-weight: 700;
	padding-top: 15px;
}
/* Yuko Product Page */
.entry-summary .r_rw_container_wrapper {
	margin-bottom: 30px;
}
/* Yuko Carousel Widget */
.yuko-reviews-carousal-widget-iframe-container {
	max-height: 700px;
}
/* Help Scout My Account Buttons */
.tgwc-woocommerce-customize-my-account #tgwc-woocommerce:not([data-menu-layout=legacy]) .woocommerce-MyAccount-content .button,
.tgwc-woocommerce-customize-my-account #tgwc-woocommerce:not([data-menu-layout=legacy]) .woocommerce-MyAccount-content .show-password-input {
