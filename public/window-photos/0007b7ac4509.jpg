</div>

<script>
    const hideModal = () => {
        document.querySelector("#pl-search-bar").innerHTML = "";
    }
    const renderModal = (visible) => {
        const SearchBar = window.PartslogicUi.WsmSearchBarWrapperModal;
        const element = document.querySelector("#pl-search-bar");
        const sku = "2193"
        const fitment = localStorage.getItem("sui-fitment-selector-v2");
        const root = window.ReactDOM.createRoot(element);
        const SearchBarComponent = window.React.createElement(SearchBar, {
            onClose: () => {
                root.unmount()
            },
            styled: true,
            show: visible,
            showRecentTerms: false,
            fitment: fitment !== "[]" && fitment ? Object.values(JSON.parse(fitment)).join(" ") : null, 
            onClearFitment: () => {
                localStorage.removeItem("sui-fitment-selector-v2");
                const newUrl = new URL(window.location.href);
                newUrl.searchParams.delete("fitment");
                window.location.href = newUrl;
                const newEvent = new CustomEvent("Fitment changed", {detail: null});
                window.dispatchEvent(newEvent);
            },
            onSubmit: (e) => {
                window.location.href = `/search.php?q=${encodeURI(e)}`;
            }
        });
        root.render(SearchBarComponent);
    }
    const clickableSearchBar = document.querySelector("#clickable-search-bar");
    clickableSearchBar.addEventListener("click", () => {
        renderModal(true)
        setTimeout(() => {
            document.querySelector("#sui-search-bar-input").focus()
        }, 200)
        /* Animate the search modal down, disable for now
            setTimeout(() => {
            const modal = document.querySelector(".style_searchBarModal__mtEH7");
            modal.style.transition = ".5s";
            const displacement = clickableSearchBar.getBoundingClientRect().top - clickableSearchBar.getBoundingClientRect().height - 12;
            modal.style.top = `${displacement}px`;
        }, 100) */
    })
</script>

