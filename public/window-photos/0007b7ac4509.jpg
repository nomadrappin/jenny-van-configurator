  <div id="pl-fitment-selector">
</div>
<style>
    #pl-fitment-selector {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 10px;
        box-sizing: border-box;
    }
    #pl-fitment-selector .Sui-FitmentSelector--select-wrapper {
        margin-right: 5px;
    }
    @media screen and (orientation: portrait) {
        #pl-fitment-selector .Sui-FitmentSelector--select-wrapper {
        margin-right: 0;
    }
    }
</style>
<script>
    const renderFitmentSelector = () => {
        const FitmentSelector = window.PartslogicUi.WsmFitmentSelectorWrapper;
        const sku = "2193"
        const FitmentSelectorComponent = window.React.createElement(FitmentSelector, {
            sku,
            groupId: window.PartslogicUi.groupId,
            styled: true,
            orientation: "horizontal",
            searchButtonText: "Save",
            onSubmit: (e) => {
                if (window.location.pathname === "/search.php")  {
                    window.location.reload();
                }
                else {
                    window.location.href = "/search.php";
                }
            }
        });
        const root = window.ReactDOM.createRoot(document.querySelector("#pl-fitment-selector"));
        root.render(FitmentSelectorComponent);
        setTimeout(() => {
            const clearBtn = document.querySelector("#pl-fitment-selector .Sui-FitmentSelector--clearBtn");
            clearBtn.addEventListener("click", () => {
                window.location.reload();
            })
        }, 1500)
        
    }
    if (window.PartslogicUi && window.PartslogicUi.ready) {
        renderFitmentSelector();
    }
    else {
        window.addEventListener("Partslogic ready", renderFitmentSelector)
    }
</script>
