  <script>
    window.productGSWGroupSelector = 'product-info .product__description.rte';
  </script><script>
(function(){
  if (!document.body.classList.contains('template-product')) return;

  const modal = document.getElementById('complementary-modal');
  if (!modal) return; // no metafield set on this product

  const openModal = () => { if (modal.querySelector('.comp-card')) modal.classList.remove('hidden'); };
  const closeModal = () => modal.classList.add('hidden');

  document.addEventListener('click', e => {
    if (e.target.matches('[data-close-modal]') || e.target.closest('[data-close-modal]')) closeModal();
  });

  // 2a) Open after theme's own fetch to /cart/add
  const _fetch = window.fetch;
  window.fetch = async function(input, init){
    const isAdd = typeof input === 'string' && input.indexOf('/cart/add') > -1;
    const res = await _fetch.apply(this, arguments);
    if (isAdd && res && res.ok) openModal();
    return res;
  };

  // 2b) Fallback for XHR-based themes
  const _send = XMLHttpRequest.prototype.send;
  XMLHttpRequest.prototype.send = function(body){
    this.addEventListener('load', function(){
      try {
        const url = this.responseURL || '';
        if (url.indexOf('/cart/add') > -1 && this.status >= 200 && this.status < 300) openModal();
      } catch(e){}
    });
    return _send.apply(this, arguments);
  };

  // 2c) Last fallback if a form posts with a hard redirect
  document.addEventListener('submit', function(e){
    const form = e.target;
    if (form.matches('form[action*="/cart/add"]:not(.complementary-add)')) {
      e.preventDefault(); // keep user on product page
      const fd = new FormData(form);
      fetch('/cart/add.js', { method: 'POST', body: fd, headers: {'X-Requested-With':'XMLHttpRequest'} })
        .then(r => { if (r.ok) openModal(); else return r.json().then(j=>{throw j}); })
        .catch(err => alert(err && err.description ? err.description : 'Could not add to cart'));
    }
    if (form.matches('.complementary-add')) {
      e.preventDefault();
      const fd2 = new FormData(form);
      fetch('/cart/add.js', { method: 'POST', body: fd2, headers: {'X-Requested-With':'XMLHttpRequest'} })
        .then(r => { if (r.ok) return; else return r.json().then(j=>{throw j}); })
        .catch(err => alert(err && err.description ? err.description : 'Could not add item'));
    }
  });
})();
</script>





