  window.GPOConfigs.shop = {"url":"backland-expedition-gear.myshopify.com","version":2,"settings":{"general":{"widget":{"app_position":"before_variant","html_selector":null,"alignment":"left","show_tooltip":true,"show_value_next_label":true,"fixed_height_and_scrollable":false,"fixed_height":"900","swatch_image_format":"jpg","watermark":"\u003cspan style=\"font-size:12px;color:#868686\"\u003ePowered by \u003ca style=\"font-weight:bold;color:#2c6ecb;text-decoration:none;\" href=\"https:\/\/apps.shopify.com\/product-options-pro\" target=\"_blank\"\u003eGlobo Variant Option\u003c\/a\u003e\u003c\/span\u003e","enable_remove_watermark":true,"remove_all_watermarks":true},"collection_page":{"show_on_quickview":true},"product_page":{"redirect_to_cart":true,"scroll_to_invalid":true,"file_preview":"link_or_image"},"cart_page":{"disable_quantity_and_remove":true,"edit_options":true},"others_page":{"show_on_homepage":true,"show_on_page":true}},"design":{"color":{"app_background":"#fff","label_text":"#1f1f21","required_text":"#e8a251","helptext":"#939393","total_text":"#1f1f21","total_text_money":"#1f1f21","input_text":"#1f1f21","input_border":"#4D5D32","input_background":"#fff","select_text":"#1f1f21","select_border":"#4D5D32","select_background":"#fff","switch_background":"#D7CFB7","switch_active_background":"#768F4D","choicelist_text":"#1f1f21","choicelist_text_hover":"#1f1f21","choicelist_text_active":"#1f1f21","choicelist_hover":"#768F4D","choicelist_active":"#768F4D","button_text":"#000000","button_text_hover":"#000000","button_text_active":"#000000","button_background":"#fff","button_background_hover":"#768F4D","button_background_active":"#768F4D","swatch_border":"#768F4D","swatch_border_hover":"#4D5D32","swatch_border_active":"#768F4D","tab_title":"#4D5D32","tab_title_active":"#768F4D","tab_title_hover":"#768F4D","tab_content":"#1f1f21","tab_border":"#4D5D32","select_selected":"#D7CFB7","group_chevron":"#4D5D32","group_icon":"#4D5D32","group_label":"#4D5D32","range_bg":"#D7CFB7"},"border":{"input":{"size":1,"radius":5},"dropdown":{"size":1,"radius":5},"swatch":{"size":1,"radius":5}},"typography":{"labeltext":{"customFont":false,"customFontFamily":null,"customFontVariant":"500","fontFamily":"Montserrat","fontVariant":"500","fontSize":13},"maintext":{"customFont":false,"customFontFamily":"Lato","customFontVariant":"500","fontFamily":"Montserrat","fontVariant":"500","fontSize":13},"helptext":{"customFont":false,"customFontFamily":"Lato","customFontVariant":"400","fontFamily":"Montserrat","fontVariant":"500","fontSize":13},"totaltext":{"customFont":false,"customFontFamily":"Lato","customFontVariant":"400","fontFamily":"Montserrat","fontVariant":"700","fontSize":13}},"additional":{"custom_css":"\/* General Styling *\/\n.gpo-heading {\n    font-size: 12px;\n    padding: 1.5rem;\n    background-color: #F8F5EA;\n    border-radius: 4px;\n    margin-top: 2.5rem;\n}\n\n.gpo-paragraph {\n    font-size: 12px;\n}\n\n.gpo-label {\n    padding-top: 1rem;\n    padding-bottom: 1rem;\n}\n\n.gpo-quantity {\n    font-size: 11px;\n}\n\n.gpo-app .gpo-total-text {\n    font-size: 14px;\n    font-weight: 800;\n}\n\n\/* Tooltip Styling *\/\n.gpo-app .gpo-tooltip {\n    padding: 10px;\n    width: 350px;\n    font-size: 12px;\n    opacity: 1; \/* Tooltip is fully visible by default *\/\n    transition: opacity 0.3s ease, visibility 0.3s ease; \/* Smooth fade-out effect *\/\n}\n\n.gpo-helptext, .gpo-ov-helptext {\n    font-size: 12px;\n    line-height: normal;\n}\n\n\/* Hide the tooltip when the associated input is checked *\/\n.gpo-app .gpo-swatches input:checked + label ~ .gpo-tooltip,\n.gpo-app .gpo-swatches input:checked + label .gpo-tooltip {\n    display: none !important; \/* Completely hide the tooltip *\/\n    visibility: hidden !important; \/* Ensure it's not visible *\/\n    opacity: 0; \/* Ensure no transparency effects *\/\n    pointer-events: none; \/* Prevent interaction *\/\n}\n\n\/* Hide Tooltip on Mobile *\/\n@media (max-width: 768px) {\n    .gpo-app .gpo-tooltip {\n        display: none !important; \/* Hide tooltip completely on mobile *\/\n    }\n}\n\n\/* Swatch and Label Styling *\/\n.gpo-app .gpo-swatches input:checked + label {\n    border-color: #D7CFB7;\n    opacity: 0.3; \/* Applies to the label only *\/\n}\n\n\/* Extended Swatch Behavior *\/\n.gpo-app .gpo-swatches input:checked ~ .gpo-ov-extend .gpo-ov-quantity {\n    width: fit-content;\n}\n\n\/* OV Styling *\/\n.gpo-app .gpo-ov-extend {\n    display: block;\n}\n\n.gpo-app .gpo-ov-wrapper.horizontal,\n.gpo-app .gpo-ov-wrapper.vertical .gpo-swatches {\n    padding-bottom: 10px;\n}\n\n.gpo-app .gpo-ov-wrapper.vertical .gpo-ov-title {\n    font-size: 12px;\n    font-weight: bold;\n    font-family: \"Montserrat\", sans-serif;\n}\n\n\n.gpo-app .gpo-ov-quantity {\n    margin-top: 10px;\n    opacity: 0; \/* Initially hidden *\/\n}\n\n\/* Image Swatches Styling *\/\nlabel[for^=\"image-swatches\"] {\n    display: flex;\n    flex-direction: column;\n    align-items: center; \/* Horizontal center alignment *\/\n    justify-content: center; \/* Vertical alignment if needed *\/\n    text-align: center; \/* Fallback for text alignment *\/\n}\n\nlabel[for^=\"image-swatches\"]::after {\n    content: \"Select\"; \/* Button Text *\/\n    display: block; \/* Makes it behave like a block element *\/\n    margin: 0px auto 0; \/* Auto centers horizontally *\/\n    padding: 0px 8px; \/* Small button size *\/\n    background-color: #fff; \/* Button background *\/\n    color: #1f1f21; \/* Updated text color *\/\n    font-size: 12px; \/* Updated font size *\/\n    font-family: \"Montserrat\", sans-serif; \/* Updated font family *\/\n    font-style: normal; \/* Updated font style *\/\n    font-weight: 500; \/* Updated font weight *\/\n    border: none;\n    border-radius: 4px; \/* Rounded corners *\/\n    cursor: pointer;\n    transition: background-color 0.3s ease, transform 0.2s ease;\n    text-align: center; \/* Ensure text is centered within button *\/\n}\n"}},"price"