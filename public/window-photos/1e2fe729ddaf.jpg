4234-b3ed-dddae80f9e5e.jpg?v=1709314763"},"aspect_ratio":1.333,"height":2916,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/files\/7816DE7E-C2F5-4A09-98ED-B77890163E53_59274273-25db-4234-b3ed-dddae80f9e5e.jpg?v=1709314763","width":3888},{"alt":"Reflection of trees in AMA custom van windows","id":34344000291124,"position":5,"preview_image":{"aspect_ratio":1.0,"height":2622,"width":2622,"src":"\/\/backlandgear.com\/cdn\/shop\/files\/0685D677-4FE9-464C-9018-A62244781C6D.jpg?v=1709314763"},"aspect_ratio":1.0,"height":2622,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/files\/0685D677-4FE9-464C-9018-A62244781C6D.jpg?v=1709314763","width":2622},{"alt":"Interior side view of AMA sliding window","id":35674315391284,"position":6,"preview_image":{"aspect_ratio":1.334,"height":1536,"width":2049,"src":"\/\/backlandgear.com\/cdn\/shop\/products\/IMG_8734-944299.jpg?v=1709314761"},"aspect_ratio":1.334,"height":1536,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/products\/IMG_8734-944299.jpg?v=1709314761","width":2049},{"alt":"Exterior side view of custom van windows showing the reflection of trees.","id":34344007598388,"position":7,"preview_image":{"aspect_ratio":0.75,"height":3746,"width":2810,"src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_8732.jpg?v=1709314761"},"aspect_ratio":0.75,"height":3746,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_8732.jpg?v=1709314761","width":2810},{"alt":"Exterior side view of AMA custom van windows","id":33002113433908,"position":8,"preview_image":{"aspect_ratio":0.74,"height":2075,"width":1536,"src":"\/\/backlandgear.com\/cdn\/shop\/products\/IMG_9092.jpg?v=1709314761"},"aspect_ratio":0.74,"height":2075,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/products\/IMG_9092.jpg?v=1709314761","width":1536},{"alt":null,"id":33002113466676,"position":9,"preview_image":{"aspect_ratio":0.796,"height":1930,"width":1536,"src":"\/\/backlandgear.com\/cdn\/shop\/products\/IMG_9093.jpg?v=1709314761"},"aspect_ratio":0.796,"height":1930,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/products\/IMG_9093.jpg?v=1709314761","width":1536},{"alt":null,"id":34344007565620,"position":10,"preview_image":{"aspect_ratio":1.104,"height":2739,"width":3023,"src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_9490.jpg?v=1709314761"},"aspect_ratio":1.104,"height":2739,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_9490.jpg?v=1709314761","width":3023}],"requires_selling_plan":false,"selling_plan_groups":[],"content":"\u003ch3\u003eTransform Your Van with Custom Windows\u003c\/h3\u003e\n\u003cp\u003eEnhance your van journey with AM Auto's tinted half slider windows. Perfect for those looking for custom van windows, AM Auto expertly crafts each window with advanced design techniques. As a result, these windows meet the highest quality standards, combining style with exceptional craftsmanship. Furthermore, they offer more than just a view; they actively transform your van into a hub of elegance and practicality.\u003cbr\u003e\u003cbr\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eWe Ship Promptly: \u003c\/strong\u003e\u003cspan\u003eAfter you place an order, we get to work right away. We usually dispatch your window within a quick 3-5 business day period. Enjoy enhanced visibility and style for your Sprinter!\u003c\/span\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eNeed an installation? \u003c\/strong\u003eNot a problem, our experienced team of technicians will be happy to help you!  Add our installation services to your order below.\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e\n\u003ch5\u003eKey Features:\u003c\/h5\u003e\n\u003cul\u003e\n\u003cli style=\"text-align: left;\"\u003e\n\u003cstrong\u003e Innovative Design:\u003c\/strong\u003e Meticulously crafted with cutting-edge design trends, these custom van windows ensure a flawless OEM style fit that enhances your van's appearance.\u003c\/li\u003e\n\u003cli style=\"text-align: left;\"\u003e\n\u003cstrong\u003ePerfect Fit:\u003c\/strong\u003e AM Auto windows integrate seamlessly into Sprinter and Transit Vans, boosting their aesthetic appeal.\u003c\/li\u003e\n\u003cli style=\"text-align: left;\"\u003e\n\u003cstrong\u003eFresh Air, No Bugs:\u003c\/strong\u003e Enjoy ventilation through the expertly designed exterior screen that keeps bugs out.\u003c\/li\u003e\n\u003cli style=\"text-align: left;\"\u003e\n\u003cstrong\u003e\u003cspan\u003e \u003c\/span\u003eDurable and Quiet:\u003c\/strong\u003e The screen, embedded in a sturdy rubber channel, ensures durability and whisper-quiet operation.\u003c\/li\u003e\n\u003cli style=\"text-align: left;\"\u003e\n\u003cstrong\u003e\u003cspan\u003e \u003c\/span\u003eEnhanced Security:\u003c\/strong\u003e A magnetic latch firmly secures the window, providing added safety.\u003c\/li\u003e\n\u003cli style=\"text-align: left;\"\u003e\n\u003cstrong\u003ePrivacy and UV Protection:\u003c\/strong\u003e Benefit from privacy and shield yourself from harmful UV rays with our 15% solar privacy tint safety glass.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cp\u003eAll in all, AMA's craftsmanship turns these custom van windows into a remarkable upgrade for your vehicle's look and functionality.\u003cbr\u003e\u003cbr\u003eOEM Style Windows are available for both Sprinter and Transit Vans.\u003cbr\u003e\u003cstrong\u003e\u003c\/strong\u003e\u003c\/p\u003e"};
