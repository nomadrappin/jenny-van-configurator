5.heic?v=1709314763","\/\/backlandgear.com\/cdn\/shop\/files\/7816DE7E-C2F5-4A09-98ED-B77890163E53_59274273-25db-4234-b3ed-dddae80f9e5e.jpg?v=1709314763","\/\/backlandgear.com\/cdn\/shop\/files\/0685D677-4FE9-464C-9018-A62244781C6D.jpg?v=1709314763","\/\/backlandgear.com\/cdn\/shop\/products\/IMG_8734-944299.jpg?v=1709314761","\/\/backlandgear.com\/cdn\/shop\/files\/IMG_8732.jpg?v=1709314761","\/\/backlandgear.com\/cdn\/shop\/products\/IMG_9092.jpg?v=1709314761","\/\/backlandgear.com\/cdn\/shop\/products\/IMG_9093.jpg?v=1709314761","\/\/backlandgear.com\/cdn\/shop\/files\/IMG_9490.jpg?v=1709314761"],"featured_image":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_3342.jpg?v=1709314763","options":["Vehicle","Style"],"media":[{"alt":null,"id":36481006108980,"position":1,"preview_image":{"aspect_ratio":0.75,"height":4032,"width":3024,"src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_3342.jpg?v=1709314763"},"aspect_ratio":0.75,"height":4032,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_3342.jpg?v=1709314763","width":3024},{"alt":null,"id":36481006141748,"position":2,"preview_image":{"aspect_ratio":1.333,"height":2966,"width":3954,"src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_3329_35aba4f1-b633-4e19-8b2c-849b1be4c4b2.jpg?v=1709314763"},"aspect_ratio":1.333,"height":2966,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_3329_35aba4f1-b633-4e19-8b2c-849b1be4c4b2.jpg?v=1709314763","width":3954},{"alt":null,"id":36227980755252,"position":3,"preview_image":{"aspect_ratio":0.993,"height":2733,"width":2713,"src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_0535.heic?v=1709314763"},"aspect_ratio":0.993,"height":2733,"media_type":"image","src":"\/\/backlandgear.com\/cdn\/shop\/files\/IMG_0535.heic?v=1709314763","width":2713},{"alt":null,"id":36481020625204,"position":4,"preview_image":{"aspect_ratio":1.333,"height":2916,"width":3888,"src":"\/\/backlandgear.com\/cdn\/shop\/files\/7816DE7E-C2F5-4A09-98ED-B77890163E53_59274273-25db-