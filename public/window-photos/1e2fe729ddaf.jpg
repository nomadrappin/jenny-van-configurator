<script>
  window.addEventListener("load", function() {
    let cnt = 0;
    let int = setInterval(function(){
      cnt++;
      const widget = document.querySelector(".spp2__widget");
      const widgetOptions = document.querySelectorAll(".spp2__widget .spp2__widget-options > li");
      if(Spurit.SplitPartialPayments2 !== undefined && widgetOptions.length === 2){
        clearInterval(int);
        const full = widgetOptions[0];
        full.setAttribute('style', 'display:none');
        const depInput = document.querySelector('#spp2-installment-payment-option');
        depInput.click();
        widget.classList.add('spp2__widget_custom');
      }
      if(cnt > 50) clearInterval(int);
    },200);
});
</script>
        
	  
